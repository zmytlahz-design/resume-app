# 复制此文件为 backend/.env 并填入实际值
# Copy to backend/.env and fill in your values

# 智谱 AI
ZHIPU_API_KEY=your_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBEDDING_MODEL=embedding-3

# PostgreSQL（会话、消息、工具结果持久化；SQLAlchemy async + asyncpg）
# 本地 Docker 示例见 README「快速启动」
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_app

# 以下为可选；仓库中 redis_client.py 仍存在，主业务路由已改用 PostgreSQL
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
